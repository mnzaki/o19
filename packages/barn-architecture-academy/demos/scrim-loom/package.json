{
  "name": "@o19/scrim-loom",
  "version": "0.1.0",
  "description": "🦡 Custom warp using AAAArchi for rich architectural validation",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./warp": {
      "import": "./dist/warp/index.js",
      "types": "./dist/warp/index.d.ts"
    },
    "./heddles": {
      "import": "./dist/heddles/index.js",
      "types": "./dist/heddles/index.d.ts"
    },
    "./weaver": {
      "import": "./dist/weaver/index.js",
      "types": "./dist/weaver/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@o19/spire-loom": "workspace:*",
    "@o19/aaaarchi": "workspace:*",
    "@o19/ferror": "workspace:*",
    "@o19/orka": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.15.15",
    "typescript": "^5.9.3",
    "vitest": "^3.2.0"
  },
  "keywords": [
    "scrim",
    "weaving",
    "architecture",
    "warthog",
    "three-friends"
  ],
  "author": "Barn Architecture Academy",
  "license": "MIT"
}
