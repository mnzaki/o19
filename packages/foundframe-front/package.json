{
  "name": "@o19/foundframe-front",
  "version": "0.1.0",
  "description": "Foundational framework for o19 apps - domain layer",
  "type": "module",
  "scripts": {
    "dev": "tsc --watch",
    "tauri:dev": "tsc --watch",
    "build": "tsc",
    "lint": "eslint .",
    "check-types": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./domain": {
      "types": "./dist/src/domain/index.d.ts",
      "import": "./dist/src/domain/index.js"
    },
    "./ports": {
      "types": "./dist/src/ports/index.d.ts",
      "import": "./dist/src/ports/index.js",
      "default": "./dist/src/ports/index.js"
    },
    "./services": {
      "types": "./dist/src/services/index.d.ts",
      "import": "./dist/src/services/index.js"
    },
    "./spire/ports": {
      "types": "./dist/spire/src/ports/index.d.ts",
      "import": "./dist/spire/src/ports/index.js"
    },
    "./spire/services": {
      "types": "./dist/spire/src/services/index.d.ts",
      "import": "./dist/spire/src/services/index.js"
    }
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "@tauri-apps/api": "^2"
  }
}
