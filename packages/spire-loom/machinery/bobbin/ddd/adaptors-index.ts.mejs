{%
/**
 * Adaptors Index Template
 * Re-exports all generated adaptors
 */
const services = locals.services;
%}
/**
 * Adaptors Index
 * 
 * Re-exports all generated adaptor implementations.
 * 
 * @generated by ddd-services treadle
 */

{% for service in services %}
export {
  {{ service.entityName }}Adaptor,
  {{ service.entityName }}TauriAdaptor
} from './{{ h.snakeCase(service.entityName) }}.adaptor.js';
{% endfor %}
