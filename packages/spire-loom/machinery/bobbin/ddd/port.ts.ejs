<%
/**
 * DDD Port Template
 * Generates the port interface for a management
 */
const service = locals.service;
const entityPascal = service.entityName;
const entityCamelName = service.entityCamelName;

// Get methods from context (transformed by generateCode)
const methods = locals.methods || [];

// Filter methods for this service by management name
const serviceMethods = methods.filter(m => m.managementName === service.name);
const readMethods = serviceMethods.filter(m => ['read', 'list'].includes(m.crudOperation));
const writeMethods = serviceMethods.filter(m => ['create', 'update'].includes(m.crudOperation));
const deleteMethods = serviceMethods.filter(m => ['delete'].includes(m.crudOperation));
const passthroughMethods = serviceMethods.filter(m => !m.crudOperation);

// Helper to get CRUD method name
function getCrudMethodName(method, entityPascal, entityCamelName) {
  if (!method.crudOperation) return method.camelName;
  switch (method.crudOperation) {
    case 'create': return 'create';
    case 'read': return method.params.some(p => p.name === 'id') ? 'getById' : ('get' + entityPascal);
    case 'list': return 'list';
    case 'update': return 'update';
    case 'delete': return 'delete';
    default: return method.camelName;
  }
}
-%>
/**
 * <%= service.portName %>
 * 
 * Port interface for <%= service.entityName %> operations.
 * Generated from <%= service.name %> management methods.
 * 
 * @generated by ddd-services treadle
 */
<%_ if (entityPascal === 'TheStream') { _%>
import type { TheStreamEntry, TheStreamEntryFilter } from '@o19/foundframe-front/domain';
<%_ } else { _%> import type { <%= entityPascal %> <%_ if (entityPascal === 'MediaSource') { _%>
, MediaAdapterType, MediaSourceCapability, PollResult, MediaSourceHealth
<%_ } else if (entityPascal === 'Post') { _%>
, AccumulableBit, ConversationEntry, ConversationFilter, MediaAdapterType, MediaSourceCapability, PollResult, MediaSourceHealth
<%_ } else if (entityPascal === 'Conversation') { _%>
, ConversationEntry <%_ }

if (['Bookmark', 'Media', 'Conversation', 'Person', 'Post', 'TheStream'].includes(entityPascal)) { _%>
, <%= entityPascal %>Filter
<%_ } _%> } from '@o19/foundframe-front/domain';
<%_ } _%>

/**
 * Read adaptor interface for <%= service.entityName %>
 * Implements read/list operations
 */
export interface <%= entityPascal %>ReadPort {
<%_ for (const method of readMethods) { _%>
  <%= getCrudMethodName(method, entityPascal, entityCamelName) %>(<%- method.params.listWithOptionality %>): Promise<<%- method.returnType.replace(/\[\]$/, '') %><%= method.isCollection ? '[]' : '' %>>;

<%_ } _%>
}

/**
 * Write adaptor interface for <%= service.entityName %>
 * Implements create/update/delete operations
 */
export interface <%= entityPascal %>WritePort {

<%_ for (const method of writeMethods) { _%>
  <%= getCrudMethodName(method, entityPascal, entityCamelName) %>(data: { <%- method.params.list %> }): Promise<<%- method.returnType.replace(/\[\]$/, '') %><%= method.isCollection ? '[]' : '' %>>;
<%_ } _%>

<%_ for (const method of deleteMethods) { _%>
  <%= getCrudMethodName(method, entityPascal, entityCamelName) %>(<%- method.params.listWithOptionality %>): Promise<<%- method.returnType.replace(/\[\]$/, '') %><%= method.isCollection ? '[]' : '' %>>;
<%_ } _%>
}

/**
 * Full adaptor interface for <%= service.entityName %>
 * Implements rest operations
 */
export interface <%= service.portName %> extends <%= entityPascal %>ReadPort, <%= entityPascal %>WritePort {
<%_ for (const method of passthroughMethods) { _%>
  /**
   * <%= method.description || method.name %>
   */
  <%= getCrudMethodName(method, entityPascal, entityCamelName) %>(data: { <%- method.params.list %> }): Promise<<%- method.returnType.replace(/\[\]$/, '') %><%= method.isCollection ? '[]' : '' %>>;
<%_ } _%>
}
