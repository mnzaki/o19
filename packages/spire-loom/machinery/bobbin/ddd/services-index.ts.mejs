{%
/**
 * Services Index Template
 * Re-exports all generated services
 */
const services = locals.services;
%}
/**
 * Services Index
 * 
 * Re-exports all generated service implementations.
 * 
 * @generated by ddd-services treadle
 */

{% for service in services %}
export { {{ service.serviceName.pascalCase }} } from './{{ service.entityName.camelCase }}.service.js';
{% endfor %}
