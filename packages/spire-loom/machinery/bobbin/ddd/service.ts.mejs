{%
/**
 * DDD Service Template
 * Generates the service implementation for a management
 */
const service = locals.service;
const entityPascal = service.entityName.pascalCase;
const entityCamel = service.entityName.camelCase;

// Get methods from context (transformed by generateCode)
const methods = locals.methods || [];

// Filter methods for this service by management name
const serviceMethods = methods.filter(m => m.managementName === service.name);
const readMethods = serviceMethods.filter(m => ['read', 'list'].includes(m.crudOperation));
const writeMethods = serviceMethods.filter(m => ['create', 'update'].includes(m.crudOperation));
const passthroughMethods = serviceMethods.filter(m => !m.crudOperation);
const deleteMethods = serviceMethods.filter(m => ['delete'].includes(m.crudOperation));
%}
/**
 * {{ service.serviceName }}
 * 
 * Domain service for {{ service.entityName }} operations.
 * Routes read operations to readAdaptor, write operations to writeAdaptor.
 * 
 * @generated by ddd-services treadle
 */

{% if entityPascal === 'TheStream' %}
import type { TheStreamEntry, TheStreamEntryFilter } from '@o19/foundframe-front/domain';
{% else %}
import type { {{ entityPascal }}
{% if entityPascal === 'MediaSource' %}
  , MediaAdapterType, MediaSourceCapability, PollResult, MediaSourceHealth
{% elif entityPascal === 'Post' %}
  , AccumulableBit, ConversationEntry, ConversationFilter, MediaAdapterType, MediaSourceCapability, PollResult, MediaSourceHealth
{% elif entityPascal === 'Conversation' %}
  , ConversationEntry
{% endif %}
{% if ['Bookmark', 'Media', 'Conversation', 'Person', 'Post', 'TheStream'].includes(entityPascal) %}
  , {{ entityPascal }}Filter
{% endif %}
} from '@o19/foundframe-front/domain';
{% endif %}

import type {
  {{ service.portName }},
  {{ entityPascal }}ReadPort,
  {{ entityPascal }}WritePort
} from '@o19/foundframe-front/ports';

export class {{ service.serviceName.pascalCase }} implements {{ service.portName.pascalCase }} {
  constructor(
    private readAdaptor: {{ entityPascal }}ReadPort,
    private writeAdaptor: {{ entityPascal }}WritePort
  ) {}

  // ============================================================================
  // Read Operations (via Tauri)
  // ============================================================================
{% for method in readMethods %}

  {{ method.crud.signature }} {
    return this.readAdaptor.{{ method.crud.signature }}({{ method.paramNames.join(', ') }});
  }
{% endfor %}

  // ============================================================================
  // Write Operations (via Tauri)
  // ============================================================================
{% for method in writeMethods %}

  {{ method.crud.withObjectParams('data').signature }} {
    return this.writeAdaptor.{{ method.crud.withObjectParams('data').signature }}(data);
  }
{% endfor %}

  // ============================================================================
  // Delete Operations (via Tauri)
  // ============================================================================
{% for method in deleteMethods %}
  {{ method.crud.async.signature }} {
{% if method.raw.params.length === 0 %}
    return this.writeAdaptor.{{ method.crud.signature }}();
{% else %}
    return this.writeAdaptor.{{ method.crud.signature }}({{ method.paramNames.join(', ') }});
{% endif %}
  }
{% endfor %}

  // ============================================================================
  // Passthrough Operations (implementation-specific)
  // ============================================================================
{% for method in passthroughMethods %}

  {{ method.signature }} {
    // Passthrough method - implement based on domain logic
    throw new Error('{{ method.name }} not implemented');
  }
{% endfor %}
}
