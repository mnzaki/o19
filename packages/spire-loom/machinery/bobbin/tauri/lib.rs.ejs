impl <%= platformStructName %> {
  /// Setup the platform with an existing Foundframe instance.
  /// 
  /// This is the recommended approach - the caller creates the Foundframe
  /// instance with custom options/callbacks, then passes it here for
  /// platform management.
  /// 
  /// Call this from your plugin's setup function:
  /// ```rust
  /// .setup(|app, api| {
  ///   // 1. Create foundframe in your plugin (you control init options)
  ///   let foundframe = o19_foundframe::init(init_options, on_exit)?;
  ///   
  ///   // 2. Pass to spire for platform management
  ///   let platform = spire::setup_with_foundframe(app, api, foundframe)?;
  ///   
  ///   // 3. Use platform...
  ///   Ok(())
  /// })
  /// ```
  pub fn setup_with_foundframe<R: Runtime, C: DeserializeOwned>(
    app: &AppHandle<R>,
    _api: &PluginApi<R, C>,
    foundframe: <%= crateNaming.rustIdentifier %>::Foundframe,
  ) -> Result<Self> {
    info!("Setting up <%= platformStructName %> with existing Foundframe...");

    // Create platform implementation wrapping the existing foundframe
    #[cfg(desktop)]
    let platform = Arc::new(desktop::DesktopPlatform::from_foundframe(app.clone(), foundframe))
      as Arc<dyn <%= platformTraitName %>>;
    
    // NOTE: Mobile implementation would need similar treatment
    #[cfg(mobile)]
    let platform = Arc::new(mobile::MobilePlatform::new(app.clone(), foundframe)?)
      as Arc<dyn <%= platformTraitName %>>;

    // Manage the platform so extension trait can access it
    app.manage(platform.clone());

    info!("<%= platformStructName %> setup complete");
    Ok(Self { platform })
  }

  /// Get a reference to the platform implementation.
  pub fn platform(&self) -> &dyn <%= platformTraitName %> {
    &*self.platform
  }
}

/// Convenience function for setup with an existing Foundframe instance.
/// 
/// Use this when you want to control the Foundframe initialization yourself.
/// Returns the platform handle for direct access.
pub fn setup_with_foundframe<R: Runtime, C: DeserializeOwned>(
  app: &AppHandle<R>,
  api: &PluginApi<R, C>,
  foundframe: <%= crateNaming.rustIdentifier %>::Foundframe,
) -> Result<<%= platformStructName %>> {
  <%= platformStructName %>::setup_with_foundframe(app, api, foundframe)
}

