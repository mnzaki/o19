import { invoke } from '@tauri-apps/api/core';

<%
/**
 * DDD Adaptor Template
 * Generates Tauri adaptor implementations for the front layer
 */
const service = locals.service;
const entityPascal = service.entityName;
const entityCamel = service.entityCamelName;

// Get methods from context (transformed by generateCode)
const methods = locals.methods || [];

// Filter methods for this service by management name
const serviceMethods = methods.filter(m => m.managementName === service.name);
const readMethods = serviceMethods.filter(m => m.crudOperation === 'read' || m.crudOperation === 'list');
const writeMethods = serviceMethods.filter(m => ['create', 'update'].includes(m.crudOperation));
const deleteMethods = serviceMethods.filter(m => ['delete'].includes(m.crudOperation));
const passthroughMethods = serviceMethods.filter(m => !m.crudOperation);

// Helper to get CRUD method name
function getCrudMethodName(method, entityPascal, entityCamel) {
  if (!method.crudOperation) return method.camelName;
  switch (method.crudOperation) {
    case 'create': return 'create';
    case 'read': return method.params.some(p => p.name === 'id') ? 'getById' : ('get' + entityPascal);
    case 'list': return 'list';
    case 'update': return 'update';
    case 'delete': return 'delete';
    default: return method.camelName;
  }
}
-%>
/**
 * <%= entityPascal %> Adaptor Implementations
 * 
 * Tauri-based adaptor for <%= service.entityName %> operations.
 * All operations go through Tauri commands to the Rust core.
 * 
 * @generated by tauri-adaptor treadle
 */

<%_ if (entityPascal === 'TheStream') { _%>
import type { TheStreamEntry, TheStreamEntryFilter } from '@o19/foundframe-front/domain';
<%_ } else { _%> import type { <%= entityPascal %> <%_ if (entityPascal === 'MediaSource') { _%>
, MediaAdapterType, MediaSourceCapability, PollResult, MediaSourceHealth
<%_ } else if (entityPascal === 'Post') { _%>
, AccumulableBit, ConversationEntry, ConversationFilter, MediaAdapterType, MediaSourceCapability, PollResult, MediaSourceHealth
<%_ } else if (entityPascal === 'Conversation') { _%>
, ConversationEntry
<%_ }
if (['Bookmark', 'Media', 'Conversation', 'Person', 'Post', 'TheStream'].includes(entityPascal)) { _%>
, <%= entityPascal %>Filter
<%_ } _%> } from '@o19/foundframe-front/domain';
<%_ } _%>
import type {
  <%= service.portName %>,
  <%= entityPascal %>ReadPort,
  <%= entityPascal %>WritePort
} from '@o19/foundframe-front/ports';

/**
 * Tauri-based adaptor for <%= service.entityName %>
 */
export class Tauri<%= entityPascal %>Adaptor implements <%= entityPascal %>ReadPort, <%= entityPascal %>WritePort {

<%_ for (const method of passthroughMethods) { _%>
  async <%= getCrudMethodName(method, entityPascal, entityCamel) %>(data: { <%- method.params %> }): Promise<<%- method.returnType.replace(/\[\]$/, '') %><%= method.isCollection ? '[]' : '' %>> {
    return invoke('plugin:<%= pluginName %>|<%= method.name %>', data);
  }
<%_ } _%>

<%_ for (const method of readMethods) { _%>
  async <%= getCrudMethodName(method, entityPascal, entityCamel) %>(<%
  if (method.params.length > 1) { %> data: { <%- method.params %> } <% } else { %>
  <%- method.params %>
  <% } %>): Promise<<%- method.returnType.replace(/\[\]$/, '') %><%= method.isCollection ? '[]' : '' %>> {
    return invoke('plugin:<%= pluginName %>|<%= method.name %>' <% if (method.params.length > 1) { %>
      , data
    <% } else if (method.params.length == 1) { %>
      , { <%- method.params[0].name %> }
    <% } %>);
  }
<%_ } _%>

/**
 * Write adaptor interface for <%= service.entityName %>
 * Implements create/update/delete operations
 */

<%_ for (const method of writeMethods) { _%>
  <%= getCrudMethodName(method, entityPascal, entityCamel) %>(data: { <%- method.params %> }): Promise<<%- method.returnType.replace(/\[\]$/, '') %><%= method.isCollection ? '[]' : '' %>> {
    return invoke('plugin:<%= pluginName %>|<%= method.name %>', data);
  }
<%_ } _%>

<%_ for (const method of deleteMethods) { _%>
  <%= getCrudMethodName(method, entityPascal, entityCamel) %>(<%- method.params %>): Promise<<%- method.returnType.replace(/\[\]$/, '') %><%= method.isCollection ? '[]' : '' %>> {
    return invoke('plugin:<%= pluginName %>|<%= method.name %>', { <%= method.params.map(p => p.name).join(', ') %> });
  }
<%_ } _%>

}

/**
 * Convenience export - single adaptor handles all operations
 */
export { Tauri<%= entityPascal %>Adaptor as <%= entityPascal %>Adaptor };
